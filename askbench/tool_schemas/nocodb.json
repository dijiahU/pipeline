  {
    "type": "function",
    "function": {
      "name": "update_record_by_field",
      "description": "Match a record by business field and update it.",
      "parameters": {
        "type": "object",
        "properties": {
          "table_id": {
            "type": "string",
            "description": "Table ID or name."
          },
          "match_field": {
            "type": "string",
            "description": "Field name used to locate the record, for example 'ProjectCode'."
          },
          "match_value": {
            "type": "string",
            "description": "Field value used to locate the record."
          },
          "fields": {
            "type": "object",
            "description": "Field key/value pairs to update."
          },
          "base_id": {
            "type": "string",
            "description": "Database ID or name. Required when table_id is a name."
          },
          "require_unique": {
            "type": "boolean",
            "description": "Whether the match must be unique. Default: true."
          }
        },
        "required": [
          "table_id",
          "match_field",
          "match_value",
          "fields"
        ]
      }
    }
  },
