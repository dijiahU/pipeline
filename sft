    "tool_args": {
      "from_email": "admin@example.com",
      "to_email": "alice@example.com",
      "subject": "Scheduled Maintenance Tonight",
      "body": "The email system will be maintained between 22:00-23:00 tonight. During this period, the email service may be temporarily interrupted."
